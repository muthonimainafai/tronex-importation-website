<IfModule mod_rewrite.c>
    RewriteEngine On

    # Pass Authorization header to PHP (required for admin API Bearer tokens on Apache)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Static assets live under public/ (works in subdirectory installs)
    RewriteRule ^(css|js|images|uploads)(/.*)?$ public/$1$2 [L]

    # PHP front controller
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L,QSA]
</IfModule>

# PHP upload limits (adjust if your host allows)
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
</IfModule>
